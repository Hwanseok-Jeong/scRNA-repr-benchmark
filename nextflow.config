conda {
    enabled = true
}

process {
    conda = false
}

params {
    data_dir = "${projectDir}/data"
    results_dir = "${projectDir}/results"
    methods = ['pca', 'scvi']
    run_batch_explore = true

    preprocessing {
        dataset_url = "https://cf.10xgenomics.com/samples/cell-exp/3.0.0/pbmc_1k_v3/pbmc_1k_v3_filtered_feature_bc_matrix.h5"
        n_hvg = 3000
        target_sum = 1000000
        log_transform = true
        marker_genes = ["Snap25", "Gad1", "Slc17a7", "Pvalb", "Sst", "Vip", "Aqp4", "Mog", "Itgam", "Pdgfra", "Flt1", "Bgn", "Rorb", "Foxp2"]
    }

    latent_models {
        latent_dim = 50
        scvi {
            n_latent_list = [10,20,30,50]
            n_layers = 2
            n_hidden = 128
            dropout_rate = 0.1
            gene_likelihood = "zinb"
            layer = "counts"
            dispersion = "gene"
            max_epochs = 200
            early_stopping = true
            patience = 10
            batch_size = 128
            learning_rate = 0.001
        }
    }

    embed_tsne {
        initialization = "pca"
        perplexity = "N/100"
        learning_rate = "N/12"
        early_exaggeration = 12
        late_exaggeration = false
        variants = [
            [name: "default", perplexity: 30, initialization: "random", learning_rate: 200, seed: 42],
            [name: "n100", perplexity: "N/100", initialization: "random", learning_rate: 200, seed: 42],
            [name: "pca_init", perplexity: 30, initialization: "pca", learning_rate: 200],
            [name: "multiscale_pca_high_lr", perplexity_list: [30, "N/100"], initialization: "pca", learning_rate: "N/12"],
        ]
    }

    embed_umap {
        n_neighbors = 30
        min_dist = 0.3
        variants = [
            [name: "n15_md01", n_neighbors: 15, min_dist: 0.1],
            [name: "n30_md05", n_neighbors: 30, min_dist: 0.5],
        ]
    }
}
